{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "phillip-deeley-website",
  "main": "worker.js",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "phillipdeeley.com/contact", "zone_name": "phillipdeeley.com" }
  ]
}
